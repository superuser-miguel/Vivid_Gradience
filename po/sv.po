#: data/com.github.superuser-miguel.VividGradience.appdata.xml.in.in:6
#: gradience/frontend/views/about_dialog.py:41
msgid "Gradience Team"
msgstr "Gradience Team"

#: data/com.github.superuser-miguel.VividGradience.appdata.xml.in.in:14
msgid ""
"Gradience is a tool for customizing Libadwaita applications and the adw-gtk3 "
"theme."
msgstr ""
"Gradience är ett verktyg för att anpassa Libadwaita program och adw-gtk3-"
"temat."

#: data/com.github.superuser-miguel.VividGradience.appdata.xml.in.in:15
msgid "The main features of Gradience include the following:"
msgstr "Huvudfunktionerna i Gradience inkluderar följande:"

#: data/com.github.superuser-miguel.VividGradience.appdata.xml.in.in:17
msgid "🎨️ Changing any color of Adwaita theme"
msgstr "🎨️ Ändra valfri färg på Adwaita temat"

#: data/com.github.superuser-miguel.VividGradience.appdata.xml.in.in:18
msgid "🖼️ Applying Material 3 color scheme from wallpaper"
msgstr "🖼️ Applicera Material 3 färgscheman från bakgrundsbild"

#: data/com.github.superuser-miguel.VividGradience.appdata.xml.in.in:19
msgid "🎁️ Usage of other users presets"
msgstr "🎁️ Användning av andra användares förinställningar"

#: data/com.github.superuser-miguel.VividGradience.appdata.xml.in.in:20
msgid "⚙️ Changing advanced options with CSS"
msgstr "⚙️ Ändra avancerade alternativ med CSS"

#: data/com.github.superuser-miguel.VividGradience.appdata.xml.in.in:21
msgid "🧩️ Extending functionality using plugins"
msgstr "🧩️ Utökad funktionalitet med insticksprogram"

#: data/com.github.superuser-miguel.VividGradience.appdata.xml.in.in:27
msgid "Screenshot of \"Colors\" Tab of Main UI"
msgstr "Skärmdump av \"Färger\" fliken av Huvud UI"

#: data/com.github.superuser-miguel.VividGradience.appdata.xml.in.in:32
msgid "Screenshot of \"Monet\" Tab of Main UI"
